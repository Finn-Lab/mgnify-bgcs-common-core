# ============================================================
# Secrets / environment files
# ============================================================
.env
.env.*
!.env.example
!.env.template
!.env.sample
.envrc

# ============================================================
# Virtual environments (any location)
# ============================================================
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ============================================================
# Python bytecode / caches (any location)
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.pyd

src/**/__pycache__/
src/**/*.py[cod]
src/**/*$py.class
src/**/*.pyd

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/

# ============================================================
# Packaging / build artifacts )
# ============================================================

# Standard build dirs (root or mistakenly inside src/package/)
build/
dist/
.eggs/
*.egg-info/
*.egg
*.whl
wheels/
pip-wheel-metadata/

src/**/build/
src/**/dist/
src/**/*.egg-info/
src/**/.eggs/
src/**/pip-wheel-metadata/

# ============================================================
# Coverage / test outputs
# ============================================================
.coverage
.coverage.*
coverage.xml
htmlcov/
*.cover
*.py,cover

# ============================================================
# Logs
# ============================================================
*.log


# Jupyter
.ipynb_checkpoints/

# ============================================================
# Editors / IDEs
# ============================================================
.vscode/
.idea/
*.iml

# ============================================================
# OS junk
# ============================================================
.DS_Store
Thumbs.db

# ============================================================
# Workflow / pipeline tools
# ============================================================
.nextflow*
work/
timeline.html
report.html
trace.txt

# ============================================================
# HPC / scratch
# ============================================================
**/slurm-*.out
.SCRATCH
